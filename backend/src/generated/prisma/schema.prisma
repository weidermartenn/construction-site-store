generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WorkType {
  id       String    @id @default(ulid()) @db.Uuid
  name     String    @unique @db.VarChar(250)
  unit     String    @db.VarChar(50)
  workLogs WorkLog[]

  @@map("work_type")
}

model WorkLog {
  id         String   @id @default(ulid()) @db.Uuid
  date       DateTime @db.Timestamptz()
  workTypeId String   @map("work_type_id") @db.Uuid
  volume     Float    @db.DoublePrecision
  executor   String   @db.VarChar(250)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  workType WorkType @relation(fields: [workTypeId], references: [id], onDelete: Cascade)

  @@map("work_log")
}
